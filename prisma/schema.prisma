generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  email     String?
  avatar    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  otps      OTP[]

  profile   CustomerProfile?   // 🔗 link to profile
}

model CustomerProfile {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  firstName String?
  lastName  String?
  gender    String?
  dob       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model OTP {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)

  createdAt DateTime @default(now())

  userId String?
  user   User? @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?

  // TOTP
  totpSecret   String?
  totpEnabled  Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     AdminSession[]
  profile      AdminProfile?
}

model AdminProfile {
  id        String   @id @default(uuid())

  adminId   String   @unique
  admin     Admin    @relation(fields: [adminId], references: [id])

  firstName String?
  lastName  String?
  avatar    String?
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminSession {
  id        String   @id @default(uuid())
  token     String   @unique
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
}


model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  image       String?   // category banner
  icon        String?   // small icon
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  parentId    String?
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryParent")
  metaTitle       String?
  metaDescription String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@index([parentId])
  @@index([slug])
  @@index([isActive, sortOrder])
}

enum QuantityUnit {
  PCS
  ML
  L
  G
  KG
}


model Product {
  id            String   @id @default(uuid())

  name          String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(160)

  description   String?
  shortDesc     String?  @db.VarChar(300)

  originalPrice Decimal  @db.Decimal(10,2)
  discountPrice Decimal? @db.Decimal(10,2)

  quantity      Float
  quantityUnit  QuantityUnit

  tags          String[]

  isAvailable   Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  isTrending    Boolean   @default(false)
  isActive      Boolean   @default(true)

  ratingAverage Float     @default(0.0)
  ratingCount   Int       @default(0)

  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])

  images        ProductImage[]

  metaTitle       String? @db.VarChar(160)
  metaDescription String? @db.VarChar(300)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isTrending])
}

enum ProductImageType {
  MAIN
  GALLERY
}

model ProductImage {
  id        String   @id @default(uuid())

  url       String
  type      ProductImageType
  sortOrder Int      @default(0)

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
}